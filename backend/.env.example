# ─────────────────────────────────────────────────────────────
# NSG Cotizador — Variables de Entorno
# ─────────────────────────────────────────────────────────────

# ── Base de Datos PostgreSQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nsg_cotizaciones
DB_USER=postgres
DB_PASSWORD=

# ── Seguridad ────────────────────────────────────────────────
JWT_SECRET=
ENCRYPTION_KEY=

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── API Tipo de Cambio USD/PEN ──────────────────────────────
APIS_NET_TOKEN=

# ── Asistente IA — Google Gemini (fallback legacy) ────────────
GEMINI_API_KEY=
GEMINI_MODEL=

# ── Asistente IA — Pipeline Multi-Agente NVIDIA ─────────────
NVIDIA_API_KEY=
NVIDIA_BASE_URL=

# Modelos del pipeline
#CLASSIFIER_MODEL
#EMBEDDING_MODEL
#RERANKER_MODEL
NVIDIA_CLASSIFIER_MODEL=meta/llama-3.2-3b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embed-v1
NVIDIA_RERANKER_MODEL=nvidia/rerank-qa-mistral-4b

# Cache de embeddings
EMBEDDING_CACHE_TTL=300
EMBEDDING_CACHE_MAX_ITEMS=500

# Timeout y feature flag del pipeline
AGENT_PIPELINE_TIMEOUT_MS=15000
AGENT_PIPELINE_ENABLED=true

# ── Asistente IA — Configuración general ────────────────────
ASISTENTE_MAX_INTENTOS_VALIDACION=3
ASISTENTE_RATE_LIMIT_POR_IP=20
ASISTENTE_HISTORIAL_DIAS=90
ASISTENTE_MAX_HISTORIAL_MENSAJES=8
WHATSAPP_NUMERO_ASESOR=

# ── Correo SMTP (recuperación de contraseña) ────────────────
SMTP_HOST=
# Opcional: usar IP directa para evitar fallos DNS locales
SMTP_HOST_IP=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# == Icecat API (POC enriquecimiento - scripts/poc-icecat) ==
# Credenciales de TU cuenta Icecat. NO usar el demo openIcecat-live (catalogo recortado).
ICECAT_API_TOKEN=
ICECAT_CONTENT_TOKEN=
ICECAT_SHOPNAME=
ICECAT_LANG=

# == Cloudflare Turnstile (captcha login/registro) ==
# Si TURNSTILE_SECRET_KEY esta vacio, la verificacion se omite (modo dev).
TURNSTILE_SECRET_KEY=

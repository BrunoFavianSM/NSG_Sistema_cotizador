# ConfiguraciÃ³n de Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nsg_cotizaciones
DB_USER=nsg_user
DB_PASSWORD=secure_password

# ConfiguraciÃ³n de Seguridad
JWT_SECRET=min_32_caracteres_aleatorios_cambiar_en_produccion
ENCRYPTION_KEY=64_caracteres_hex_para_aes256_cambiar_en_produccion

# Asistente IA v3 (proveedores soportados)
# Prioridad fija: Google AI Studio -> NVIDIA
GOOGLE_AI_STUDIO_API_KEY=tu_api_key_de_google_ai_studio
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-flash
NVIDIA_API_KEY=tu_api_key_de_nvidia
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# Compatibilidad opcional (alias de Google en despliegues previos)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optimizacion de consumo IA
AI_TIMEOUT_MS=300000
AI_MAX_RETRIES=1
ASISTENTE_MAX_HISTORIAL_MENSAJES=8
# Numero maximo de intentos del loop Double-Check antes de ofrecer asesor humano
ASISTENTE_MAX_INTENTOS_VALIDACION=3
# Limite de peticiones por minuto por IP (usuarios anonimos)
ASISTENTE_RATE_LIMIT_POR_IP=20
# Dias de retencion del historial de conversaciones del asistente
ASISTENTE_HISTORIAL_DIAS=90
# Numero de WhatsApp del asesor humano (formato internacional sin +)
WHATSAPP_NUMERO_ASESOR=51999999999

# ConfiguraciÃ³n del Servidor
PORT=3000
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# ConfiguraciÃ³n de ReplicaciÃ³n (Opcional)
DB_MASTER_HOST=localhost
DB_REPLICA_HOST=localhost

# Redis (Opcional para cache)
REDIS_HOST=localhost
REDIS_PORT=6379




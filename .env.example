# Configuración de Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nsg_cotizaciones
DB_USER=nsg_user
DB_PASSWORD=secure_password

# Configuración de Seguridad
JWT_SECRET=min_32_caracteres_aleatorios_cambiar_en_produccion
ENCRYPTION_KEY=64_caracteres_hex_para_aes256_cambiar_en_produccion

# API de Inteligencia Artificial (legado)
AI_API_KEY=tu_api_key_de_gemini_o_openai

# Asistente IA - Google Gemini
# Clave de API de Google Gemini (nunca exponer al cliente)
GEMINI_API_KEY=tu_api_key_de_google_gemini
# Modelo de Gemini a utilizar (ej: gemini-1.5-flash, gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash
# Numero maximo de intentos del loop Double-Check antes de ofrecer asesor humano
ASISTENTE_MAX_INTENTOS_VALIDACION=3
# Limite de peticiones por minuto por IP (usuarios anonimos)
ASISTENTE_RATE_LIMIT_POR_IP=20
# Dias de retencion del historial de conversaciones del asistente
ASISTENTE_HISTORIAL_DIAS=90
# Numero de WhatsApp del asesor humano (formato internacional sin +)
WHATSAPP_NUMERO_ASESOR=51999999999

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Configuración de Replicación (Opcional)
DB_MASTER_HOST=localhost
DB_REPLICA_HOST=localhost

# Redis (Opcional para cache)
REDIS_HOST=localhost
REDIS_PORT=6379
